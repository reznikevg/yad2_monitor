# Copy to .env or export in shell. Used by --send-now and scheduler for Telegram + WhatsApp.

# Telegram: create bot via @BotFather, then get chat_id (e.g. message your bot and visit https://api.telegram.org/bot<TOKEN>/getUpdates)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=123456789

# WhatsApp: URL that accepts POST with JSON body { "text": "..." } and forwards to your WhatsApp (e.g. Make.com, n8n, or custom gateway)
WHATSAPP_WEBHOOK_URL=https://your-gateway.com/webhook/xxx
